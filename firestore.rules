rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'diazoniamsalt@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidOrder(data) {
      return data.keys().hasAll(['uniqueOrderNumber', 'customerName', 'phone', 'address', 'items', 'totalAmount', 'status', 'createdAt']) &&
             data.uniqueOrderNumber is string && data.uniqueOrderNumber.size() <= 100 &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.address is string && data.address.size() <= 1000 &&
             data.items is list && data.items.size() <= 50 &&
             data.totalAmount is number &&
             data.status in ['pending', 'shipping', 'delivered'] &&
             data.createdAt is timestamp;
    }

    function isValidCartActivity(data) {
      return data.keys().hasAll(['sessionId', 'items', 'updatedAt']) &&
             data.sessionId is string && data.sessionId.size() <= 128 &&
             data.items is list && data.items.size() <= 50 &&
             data.updatedAt is timestamp;
    }

    // Collection Rules
    match /orders/{orderId} {
      allow read: if true;
      allow list: if true;
      allow create: if isValidOrder(incoming()) && incoming().status == 'pending' && incoming().createdAt == request.time;
      allow update: if true;
      allow delete: if true;
    }

    match /cartActivities/{activityId} {
      allow read: if true;
      allow create: if isValidCartActivity(incoming()) && incoming().updatedAt == request.time;
      allow update: if isValidCartActivity(incoming()) && incoming().updatedAt == request.time;
      allow delete: if isValidId(activityId);
      allow list: if true;
    }

    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
    
    // Connectivity test doc
    match /test/connection {
      allow get: if true;
    }
  }
}
